# PolyBMiCoB configuration
# Copy this to .env and fill in your values:  cp .env.example .env

# Bot mode: "dry-run" (default, no real trades) or "live" (real orders with real money!)
BOT_MODE=dry-run

# Polygon RPC endpoint (free public endpoint, no API key needed)
CHAINSTACK_NODE=https://polygon-bor-rpc.publicnode.com

# Your EVM private key (Polygon) - REQUIRED
POLYBMICOB_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Polymarket proxy wallet address (from Polymarket UI > Profile > Address)
# This is the "funder" address for POLY_PROXY signature type - REQUIRED
POLYMARKET_PROXY_WALLET=0xYOUR_PROXY_WALLET_ADDRESS_HERE

# Signature type: 1 = POLY_PROXY (Magic Link accounts), 0 = EOA
SIGNATURE_TYPE=1

# Chain ID: 137 = Polygon mainnet
CHAIN_ID=137

# CLOB API endpoint
CLOB_HOST=https://clob.polymarket.com

# Trading parameters
MAX_TRADE_USD=1.00
MIN_BALANCE_USD=3.00
MAX_OPEN_POSITIONS=3
MIN_EDGE=0.10
# Asymmetric edge: separate thresholds for UP and DOWN (overrides MIN_EDGE per direction)
# DOWN has historically higher WR, so lower threshold is appropriate
#MIN_EDGE_UP=0.12
#MIN_EDGE_DOWN=0.06

# Hour-of-day filter (comma-separated UTC hours, empty = trade all hours)
# Based on backtest best hours: 00,04,07,08,14,15,16,17,18
#TRADING_HOURS_UTC=00,04,07,08,14,15,16,17,18

# Volatility filter - skip trades when BTC is too choppy (high reversal risk)
# 0.12 = typical 5m vol threshold, 0 = disabled
MAX_VOL_5M=0.12

# Minimum BTC momentum to trigger pre-market signal (%, default 0.05)
MIN_MOMENTUM_PCT=0.05
MAX_DAILY_LOSS_USD=3.00
MAX_CONSECUTIVE_LOSSES=5
PAUSE_AFTER_LOSSES_SEC=1800

# Dashboard
DASHBOARD_PORT=8005

# Timing
SCAN_INTERVAL_SEC=45
SCAN_MIN_MINUTES=1.0
SCAN_MAX_MINUTES=6.0
RATE_LIMIT_SEC=1.5

# In-play mode: bet on markets already running based on real BTC movement
IN_PLAY_ENABLED=true
IN_PLAY_MIN_ELAPSED_SEC=60
IN_PLAY_MAX_ELAPSED_SEC=180
IN_PLAY_MIN_MOVE_PCT=0.08

# Maximum execution price per share (skip trades with bad risk/reward)
# At $0.65: risk $3.25, win $1.75 (R:R=0.54). At $0.85: risk $4.25, win $0.75 (R:R=0.18)
MAX_EXEC_PRICE=0.65

# Volume filter: skip markets with low trading volume (USD)
# Low-volume markets have unreliable orderbooks, wide spreads, and noisy signals
# Set to 0 to disable (default). Applies to both pre-market and in-play scans.
#MIN_VOLUME_USD=100

# Kelly criterion: dynamic position sizing based on edge and confidence
# Quarter-Kelly (0.25x) is conservative - protects against model errors
KELLY_ENABLED=false
KELLY_MULTIPLIER=0.25
KELLY_MIN_USD=1.00
KELLY_MAX_USD=5.00

# Insurance bet: after in-play trade, buy $1 of cheap opposite side as reversal insurance
# Profitable when opposite token < $0.15 (EV +$0.66 at 15% reversal rate)
INSURANCE_ENABLED=false
INSURANCE_BUDGET_USD=1.00
INSURANCE_MAX_PRICE=0.15

# Flash crash detector: buy undervalued tokens when price drops without BTC justification
# Detects anomalies where token drops >20% but BTC moved <0.05% (mean reversion opportunity)
FLASH_CRASH_ENABLED=false
FLASH_CRASH_MIN_DROP_PCT=20.0
FLASH_CRASH_MAX_BTC_PCT=0.05
FLASH_CRASH_MAX_PRICE=0.35
FLASH_CRASH_BUDGET_USD=1.00

# Black-Scholes fair value: replace heuristic momentum probability with mathematical model
# Uses realized BTC volatility (30x1m klines) to compute P(BTC continues direction)
# d2 = current_move / (sigma * sqrt(T_remaining)), P(up) = N(d2)
# More conservative than heuristic near 50/50, more aggressive on strong moves
BS_ENABLED=false

# Maker mode: use GTC post-only orders for pre-market (earn maker rebate instead of paying taker fee)
# Makers pay $0 fee on Polymarket crypto markets and earn a share of the 20% rebate pool
# Only applies to pre-market orders. In-play/insurance/hedge/flash-crash still use FOK (time-critical)
# Order is placed at best_bid + $0.01, monitored for MAKER_TIMEOUT_SEC, then cancelled if not filled
MAKER_MODE_ENABLED=false
MAKER_TIMEOUT_SEC=120

# Late-game hedge: buy opposite side cheap near market end to lock profit
HEDGE_ENABLED=true
HEDGE_MAX_PRICE=0.45
HEDGE_WINDOW_SEC=60

# Early exit: sell positions early to cut losses (disabled by default = hold-to-resolution)
# When enabled, monitors open positions and sells if:
#   - Token price drops below STOP_LOSS_THRESHOLD (e.g. 30c = sell at small loss vs total loss)
#   - BTC reverses direction by MOMENTUM_REVERSAL_PCT while still in profit (lock in gains)
EARLY_EXIT_ENABLED=false
STOP_LOSS_THRESHOLD=0.30
MOMENTUM_REVERSAL_PCT=0.15

# Builder API credentials (for gasless claiming via Polymarket relayer)
# Register at https://builders.polymarket.com to get these (free, Unverified tier = 100 tx/day)
POLY_BUILDER_API_KEY=
POLY_BUILDER_SECRET=
POLY_BUILDER_PASSPHRASE=

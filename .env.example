# PolyBMiCoB configuration
# Copy this to .env and fill in your values:  cp .env.example .env

# Bot mode: "dry-run" (default, no real trades) or "live" (real orders with real money!)
BOT_MODE=dry-run

# Polygon RPC endpoint (free public endpoint, no API key needed)
CHAINSTACK_NODE=https://polygon-bor-rpc.publicnode.com

# Your EVM private key (Polygon) - REQUIRED
POLYBMICOB_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Polymarket proxy wallet address (from Polymarket UI > Profile > Address)
# This is the "funder" address for POLY_PROXY signature type - REQUIRED
POLYMARKET_PROXY_WALLET=0xYOUR_PROXY_WALLET_ADDRESS_HERE

# Signature type: 1 = POLY_PROXY (Magic Link accounts), 0 = EOA
SIGNATURE_TYPE=1

# Chain ID: 137 = Polygon mainnet
CHAIN_ID=137

# CLOB API endpoint
CLOB_HOST=https://clob.polymarket.com

# Trading parameters
MAX_TRADE_USD=1.00
MIN_BALANCE_USD=3.00
MAX_OPEN_POSITIONS=3
MIN_EDGE=0.10
MAX_DAILY_LOSS_USD=3.00
MAX_CONSECUTIVE_LOSSES=5
PAUSE_AFTER_LOSSES_SEC=1800

# Dashboard
DASHBOARD_PORT=8005

# Timing
SCAN_INTERVAL_SEC=45
SCAN_MIN_MINUTES=1.0
SCAN_MAX_MINUTES=6.0
RATE_LIMIT_SEC=1.5

# Builder API credentials (for gasless claiming via Polymarket relayer)
# Register at https://builders.polymarket.com to get these (free, Unverified tier = 100 tx/day)
POLY_BUILDER_API_KEY=
POLY_BUILDER_SECRET=
POLY_BUILDER_PASSPHRASE=
